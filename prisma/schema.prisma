generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum BiologicalSex {
  MALE
  FEMALE
}

enum Goal {
  GAIN_MASS
  DEFINE
  LOSE_WEIGHT
  MAINTAIN_WEIGHT
}

enum PortionUnit {
  G
  KG
  ML
  L
  UNIT
}

enum NormalizedBase {
  PER_100G
  PER_100ML
  PER_UNIT
}

enum DietGoal {
  BULKING
  CUTTING
  RECOMPOSITION
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  passwordHash String @map("password_hash")

  isOnboardingCompleted Boolean @default(false) @map("is_onboarding_completed")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  weightHistory         WeightHistory[]
  dailyWaterConsumption DailyWaterConsumption?
  waterConsumptions     WaterConsumption[]
  dailyNutrition        DailyNutrition[]
  workoutPlans          WorkoutPlan[]
  diets                 Diet[]

  workoutConfig WorkoutConfig?
  profile       Profile?
  foods         Food[]
  recipes       Recipe[]

  @@map("users")
}

model Profile {
  id String @id @default(uuid())

  goal                Goal
  biologicalSex       BiologicalSex @map("biological_sex")
  birthDate           DateTime      @map("birth_date") @db.Date()
  heightInCentimeters Int           @map("height_in_centimeters")

  weightInGrams       Int @map("weight_in_grams")
  targetWeightInGrams Int @map("target_weight_in_grams")

  timezone  String   @default("America/Sao_Paulo")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model DailyNutrition {
  id  String   @id @default(uuid())
  day DateTime @db.Date

  proteinsInGrams Int @default(0) @map("proteins_in_grams")
  carbsInGrams    Int @default(0) @map("carbs_in_grams")
  fatsInGrams     Int @default(0) @map("fats_in_grams")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@map("daily_nutritions")
}

model Diet {
  id       String  @id @default(uuid())
  isActive Boolean @default(true) @map("is_active")

  totalCaloriesInKcal  Int @map("total_calories_in_kcal")
  totalProteinsInGrams Int @map("total_proteins_in_grams")
  totalCarbsInGrams    Int @map("total_carbs_in_grams")
  totalFatsInGrams     Int @map("total_fats_in_grams")

  goal DietGoal

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  meals Meal[]

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("diets")
}

model Meal {
  id            String @id @default(uuid())
  name          String
  timeInMinutes Int    @map("time_in_minutes")

  totalCaloriesInKcal  Int @map("total_calories_in_kcal")
  totalProteinsInGrams Int @map("total_proteins_in_grams")
  totalCarbsInGrams    Int @map("total_carbs_in_grams")
  totalFatsInGrams     Int @map("total_fats_in_grams")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  foods DietFood[]

  dietId String @map("diet_id")
  diet   Diet   @relation(fields: [dietId], references: [id], onDelete: Cascade)

  @@map("diet_meals")
}

model DietFood {
  id String @id @default(uuid())

  amount Int
  unit   PortionUnit

  caloriesInKcal  Int @map("calories_in_kcal")
  proteinsInGrams Int @map("proteins_in_grams")
  carbsInGrams    Int @map("carbs_in_grams")
  fatsInGrams     Int @map("fats_in_grams")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mealId String @map("meal_id")
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  foodId String @map("food_id")
  food   Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@map("diet_foods")
}

model Food {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(255)
  category    String  @db.VarChar(100)
  description String?

  normalizedBase            NormalizedBase @map("normalized_base")
  normalizedCaloriesInKcal  Int            @map("normalized_calories_in_kcal")
  normalizedProteinsInGrams Int            @map("normalized_proteins_in_grams")
  normalizedCarbsInGrams    Int            @map("normalized_carbs_in_grams")
  normalizedFatsInGrams     Int            @map("normalized_fats_in_grams")

  isCustom Boolean @default(false) @map("is_custom")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  dietFoods   DietFood[]
  recipeItems RecipeItem[]

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, isCustom])
  @@index([userId, name])
  @@map("foods")
}

model Recipe {
  id   String @id @default(uuid())
  name String

  items RecipeItem[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recipes")
}

model RecipeItem {
  id String @id @default(uuid())

  amount Int
  unit   PortionUnit

  recipeId String @map("recipe_id")
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  foodId String @map("food_id")
  food   Food   @relation(fields: [foodId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([foodId])
  @@map("recipe_items")
}

model WeightHistory {
  id            String   @id @default(uuid())
  weightInGrams Int      @map("weight_in_grams")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("weight_histories")
}

enum FocusMuscle {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  FOREARMS
  CORE
  ABS
  OBLIQUES
  GLUTES
  QUADRICEPS
  HAMSTRINGS
  CALVES
  ADDUCTORS
  ABDUCTORS
  TRAPS
  LATS
  LOWER_BACK
  NECK
  FULL_BODY
}

model WorkoutConfig {
  id                     String        @id @default(uuid())
  freeDaysPerWeek        Int           @map("free_days_per_week")
  freeTimeByDayInSeconds Int           @map("free_time_by_day_in_seconds")
  focusMuscles           FocusMuscle[] @map("focus_muscles")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workout_configs")
}

model WorkoutPlan {
  id String @id @default(uuid())

  name     String
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workoutDays WorkoutDay[]

  @@map("workout_plans")
}

model WorkoutExercise {
  id String @id @default(uuid())

  name              String
  order             Int
  reps              Int
  sets              Int
  restTimeInSeconds Int    @map("rest_time_in_seconds")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workoutDayId String     @map("workout_day_id")
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@map("workout_exercises")
}

model WorkoutDay {
  id                         String  @id @default(uuid())
  name                       String
  isRest                     Boolean @default(false) @map("is_rest")
  estimatedDurationInSeconds Int     @map("estimated_duration_in_seconds")
  coverImageUrl              String  @map("cover_image_url")
  weekDay                    WeekDay @map("week_day")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workoutPlanId String      @map("workout_plan_id")
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  exercises WorkoutExercise[]
  sessions  WorkoutSession[]

  @@map("workout_days")
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model WorkoutSession {
  id String @id @default(uuid())

  startedAt   DateTime  @map("started_at") @db.Timestamptz()
  completedAt DateTime? @map("completed_at") @db.Timestamptz()

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  workoutDayId String     @map("workout_day_id")
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@map("workout_sessions")
}

model DailyWaterConsumption {
  id           String @id @default(uuid())
  targetInMl   Int    @map("target_in_ml")
  consumedInMl Int    @default(0) @map("consumed_in_ml")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  waterConsumptions WaterConsumption[]

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("daily_water_consumptions")
}

model WaterConsumption {
  id                 String   @id @default(uuid())
  amountConsumedInMl Int      @map("amount_consumed_in_ml")
  dateOfConsumption  DateTime @map("date_of_consumption") @db.Date

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  dailyWaterConsumptionId String                @map("daily_water_consumption_id")
  dailyWaterConsumption   DailyWaterConsumption @relation(fields: [dailyWaterConsumptionId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("water_consumptions")
}
