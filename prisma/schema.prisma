generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum BiologicalSex {
  MALE
  FEMALE
}

enum UserGoal {
  GAIN_MASS
  DEFINE
  LOSE_WEIGHT
  MAINTAIN_WEIGHT
}

model User {
  id                  String         @id @default(uuid())
  name                String
  email               String         @unique
  goal                UserGoal?
  biologicalSex       BiologicalSex?
  birthDate           DateTime       @map("birth_date")
  passwordHash        String         @map("password_hash")
  weightInGrams       Int?           @map("weight_in_grams")
  heightInCentimeters Int?           @map("height_in_centimeters")
  goalWeightInGrams   Int?           @map("goal_weight_in_grams")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  weightHistory         WeightHistory[]
  waterConsumptionHistory WaterConsumptionHistory[]
  dailyNutrition        DailyNutrition[]
  waterConsumption        WaterConsumption?
  activeDiet            Diet?
  workoutConfig         WorkoutConfig?

  @@map("users")
}

model DailyNutrition {
  id              String   @id @default(uuid())
  day             DateTime
  proteinsInGrams Int      @default(0) @map("proteins_in_grams")
  carbsInGrams    Int      @default(0) @map("carbs_in_grams")
  fatsInGrams     Int      @default(0) @map("fats_in_grams")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@map("daily_nutritions")
}

model Diet {
  id              String   @id @default(uuid())
  proteinsInGrams Int      @map("proteins_in_grams")
  carbsInGrams    Int      @map("carbs_in_grams")
  fatsInGrams     Int      @map("fats_in_grams")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  goal   UserGoal
  meals  DietMeal[]
  userId String     @unique @map("user_id")
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("diets")
}

model DietMeal {
  id              String   @id @default(uuid())
  hour            String
  totalCalories   Int      @map("total_calories")
  carbsInGrams    Int      @map("carbs_in_grams")
  proteinsInGrams Int      @map("proteins_in_grams")
  fatsInGrams     Int      @map("fats_in_grams")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  foodsConsumed DietFood[]
  dietId        String     @map("diet_id")
  diet          Diet       @relation(fields: [dietId], references: [id], onDelete: Cascade)

  @@map("diet_meals")
}

model DietFood {
  id                   String  @id @default(uuid())
  name                 String
  quantity             Int
  weightPerUnitInGrams Int     @map("weight_per_unit_in_grams")
  totalCalories        Int     @map("total_calories")
  imageUrl             String? @map("image_url")

  dietMealId String   @map("diet_meal_id")
  dietMeal   DietMeal @relation(fields: [dietMealId], references: [id], onDelete: Cascade)

  @@map("diet_consumed_foods")
}

model WeightHistory {
  id            String   @id @default(uuid())
  weightInGrams Int      @map("weight_in_grams")
  createdAt     DateTime @default(now()) @map("created_at")
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("weights_history")
}

enum WorkoutGoal {
  GAIN_MASS
  DEFINITION
  LOSE_WEIGHT
}

model WorkoutConfig {
  id                     String   @id @default(uuid())
  freeWeekDays           Int      @map("free_week_days")
  freeTimeByDayInSeconds Int      @map("free_time_by_day_in_seconds")
  focusMuscles           String[] @map("focus_muscles")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  goal   WorkoutGoal @map("workout_goal")
  userId String      @unique @map("user_id")
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workouts_config")
}

model WaterConsumption {
  id           String   @id @default(uuid())
  goalInMl     Int      @default(2000) @map("goal_in_ml")
  consumedInMl Int      @default(0) @map("consumed_in_ml")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("water_consumption")
}

model WaterConsumptionHistory {
  id         String   @id @default(uuid())
  amountInMl Int      @map("amount_in_ml")
  date       DateTime

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("water_consumption_history")
}