generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum BiologicalSex {
  MALE
  FEMALE
}

enum UserGoal {
  GAIN_MASS
  DEFINE
  LOSE_WEIGHT
  MAINTAIN_WEIGHT
}

model User {
  id                  String         @id @default(uuid())
  name                String
  email               String         @unique
  goal                UserGoal?
  biologicalSex       BiologicalSex?
  birthDate           DateTime       @map("birth_date") @db.Date()
  passwordHash        String         @map("password_hash")
  weightInGrams       Int?           @map("weight_in_grams")
  heightInCentimeters Int?           @map("height_in_centimeters")
  goalWeightInGrams   Int?           @map("goal_weight_in_grams")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  weightHistory           WeightHistory[]
  waterConsumptionHistory WaterConsumptionHistory[]
  dailyNutrition          DailyNutrition[]
  waterConsumption        WaterConsumption?
  activeDiet              Diet?
  workoutPlans            WorkoutPlan[]
  workoutConfig           WorkoutConfig?

  @@map("users")
}

model DailyNutrition {
  id              String   @id @default(uuid())
  day             DateTime
  proteinsInGrams Int      @default(0) @map("proteins_in_grams")
  carbsInGrams    Int      @default(0) @map("carbs_in_grams")
  fatsInGrams     Int      @default(0) @map("fats_in_grams")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@map("daily_nutritions")
}

model Diet {
  id              String   @id @default(uuid())
  proteinsInGrams Int      @map("proteins_in_grams")
  carbsInGrams    Int      @map("carbs_in_grams")
  fatsInGrams     Int      @map("fats_in_grams")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  goal   UserGoal
  meals  DietMeal[]
  userId String     @unique @map("user_id")
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("diets")
}

model DietMeal {
  id              String   @id @default(uuid())
  hour            String
  totalCalories   Int      @map("total_calories")
  carbsInGrams    Int      @map("carbs_in_grams")
  proteinsInGrams Int      @map("proteins_in_grams")
  fatsInGrams     Int      @map("fats_in_grams")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  foodsConsumed DietFood[]
  dietId        String     @map("diet_id")
  diet          Diet       @relation(fields: [dietId], references: [id], onDelete: Cascade)

  @@map("diet_meals")
}

model DietFood {
  id                   String  @id @default(uuid())
  name                 String
  quantity             Int
  weightPerUnitInGrams Int     @map("weight_per_unit_in_grams")
  totalCalories        Int     @map("total_calories")
  imageUrl             String? @map("image_url")

  dietMealId String   @map("diet_meal_id")
  dietMeal   DietMeal @relation(fields: [dietMealId], references: [id], onDelete: Cascade)

  @@map("diet_consumed_foods")
}

model WeightHistory {
  id            String   @id @default(uuid())
  weightInGrams Int      @map("weight_in_grams")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp()
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("weights_history")
}

enum WorkoutGoal {
  GAIN_MASS
  DEFINITION
  LOSE_WEIGHT
}

model WorkoutConfig {
  id                     String   @id @default(uuid())
  freeDaysPerWeek        Int      @map("free_days_per_week")
  freeTimeByDayInSeconds Int      @map("free_time_by_day_in_seconds")
  focusMuscles           String[] @map("focus_muscles")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  goal WorkoutGoal

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workout_config")
}

model WorkoutPlan {
  id String @id @default(uuid())

  name     String
  isActive Boolean @default(true) @map("is_active")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workoutDays WorkoutDay[]

  @@map("workout_plans")
}

model WorkoutExercise {
  id String @id @default(uuid())

  name              String
  order             Int
  reps              Int
  sets              Int
  restTimeInSeconds Int      @map("rest_time_in_seconds")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workoutDayId String
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@map("workout_exercises")
}

model WorkoutDay {
  id                         String   @id @default(uuid())
  name                       String
  isRest                     Boolean  @default(false) @map("is_rest")
  estimatedDurationInSeconds Int      @map("estimated_duration_in_seconds")
  coverImageUrl              String   @map("cover_image_url")
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                  DateTime @updatedAt @map("updated_at") @db.Timestamptz
  weekDay                    WeekDay  @map("week_day")

  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id])

  exercises WorkoutExercise[]
  sessions  WorkoutSession[]

  @@map("workout_days")
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model WorkoutSession {
  id          String    @id @default(uuid())
  startedAt   DateTime  @map("started_at") @db.Timestamptz()
  completedAt DateTime? @map("completed_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  workoutDayId String     @map("workout_day_id")
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@map("workout_sessions")
}

model WaterConsumption {
  id           String   @id @default(uuid())
  goalInMl     Int      @default(2000) @map("goal_in_ml")
  consumedInMl Int      @default(0) @map("consumed_in_ml")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("water_consumption")
}

model WaterConsumptionHistory {
  id         String   @id @default(uuid())
  amountInMl Int      @map("amount_in_ml")
  date       DateTime

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("water_consumption_history")
}
