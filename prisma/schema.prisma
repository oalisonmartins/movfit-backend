generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum BiologicalSex {
  MALE
  FEMALE
}

enum Goal {
  GAIN_MASS
  DEFINE
  LOSE_WEIGHT
  MAINTAIN_WEIGHT
}

enum DietGoal {
  BULKING
  CUTTING
  RECOMPOSITION
}

model User {
  id           String @id @default(uuid())
  name         String @db.VarChar(255)
  email        String @db.VarChar(255)
  passwordHash String @map("password_hash")

  isOnboardingCompleted Boolean @default(false) @map("is_onboarding_completed")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  profile    Profile?
  weightLogs WeightLog[]

  hydrationLogs    HydrationLog[]
  hydrationEntries HydrationEntry[]

  diets Diet[]
  meals Meal[]
  foods Food[]

  workoutPlans  WorkoutPlan[]
  workoutConfig WorkoutConfig?

  nutritionEntries NutritionEntry[]
  nutritionLogs    NutritionLog[]

  @@unique([email])
  @@map("users")
}

model Profile {
  id String @id @default(uuid())

  goal                Goal
  biologicalSex       BiologicalSex @map("biological_sex")
  birthDate           DateTime      @map("birth_date") @db.Date()
  heightInCentimeters Int           @map("height_in_centimeters")

  weightInKg       Float @map("weight_in_kg")
  targetWeightInKg Float @map("target_weight_in_kg")

  timezone String @default("America/Sao_Paulo")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("profiles")
}

// NUTRITION

model NutritionLog {
  id   String   @id @default(uuid())
  date DateTime @db.Date

  calorieInKcal  Float @default(0) @map("calorie_in_kcal")
  proteinInGrams Float @default(0) @map("protein_in_grams")
  carbInGrams    Float @default(0) @map("carb_in_grams")
  fatInGrams     Float @default(0) @map("fat_in_grams")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([userId, date])
  @@index([userId, date])
  @@map("nutrition_logs")
}

model NutritionEntry {
  id String @id @default(uuid())

  amountInGrams Float    @map("amount_in_grams")
  date          DateTime @db.Date

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  foodId String @map("food_id")
  food   Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)

  dietId String @map("diet_id")
  diet   Diet   @relation(fields: [dietId], references: [id], onDelete: Cascade)

  mealId String @map("meal_id")
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([userId, dietId])
  @@index([mealId, foodId])
  @@map("nutrition_entries")
}

model Diet {
  id String @id @default(uuid())

  goal     DietGoal
  isActive Boolean  @default(true) @map("is_active")

  totalCalorieInKcal  Float  @map("total_calorie_in_kcal")
  totalProteinInGrams Float  @map("total_protein_in_grams")
  totalCarbInGrams    Float  @map("total_carb_in_grams")
  totalFatInGrams     Float  @map("total_fat_in_grams")
  meals               Meal[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nutritionEntries NutritionEntry[]

  @@index([userId, isActive])
  @@map("diets")
}

model Meal {
  id String @id @default(uuid())

  name                  String
  scheduleTimeInSeconds Int    @map("schedule_time_in_seconds")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  dietId String @map("diet_id")
  diet   Diet   @relation(fields: [dietId], references: [id], onDelete: Cascade)

  nutritionEntires NutritionEntry[]
  foods            MealFood[]

  @@unique([dietId, name])
  @@index([userId, dietId])
  @@map("meals")
}

enum FoodSource {
  TACO
  USDA
  CUSTOM
}

model MealFood {
  id String @id @default(uuid())

  amountInGrams Float @map("amount_in_grams")

  mealId String @map("meal_id")
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  foodId String @map("food_id")
  food   Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([mealId, foodId])
  @@map("meals_foods")
}

model Food {
  id            String     @id @default(uuid())
  name          String
  source        FoodSource @default(CUSTOM)
  description   String?
  coverImageUrl String?    @map("cover_image_url")
  isRecipe      Boolean    @default(false) @map("is_recipe")

  caloriePer100gInKcal  Float @map("calorie_per_100g_in_kcal")
  proteinPer100gInGrams Float @map("protein_per_100g_in_grams")
  carbPer100gInGrams    Float @map("carb_per_100g_in_grams")
  fatPer100gInGrams     Float @map("fat_per_100g_in_grams")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mealFoods        MealFood[]
  nutritionEntries NutritionEntry[]

  @@unique([userId, name])
  @@index([userId, name])
  @@map("foods")
}

model WeightLog {
  id String @id @default(uuid())

  weightInKg Float    @map("weight_in_kg")
  date       DateTime @db.Date

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("weight_logs")
}

// WORKOUT

enum FocusMuscle {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  FOREARMS
  CORE
  ABS
  OBLIQUES
  GLUTES
  QUADRICEPS
  HAMSTRINGS
  CALVES
  ADDUCTORS
  ABDUCTORS
  TRAPS
  LATS
  LOWER_BACK
  NECK
  FULL_BODY
}

model WorkoutConfig {
  id                     String        @id @default(uuid())
  freeDaysPerWeek        Int           @map("free_days_per_week")
  freeTimeByDayInSeconds Int           @map("free_time_by_day_in_seconds")
  focusMuscles           FocusMuscle[] @map("focus_muscles")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workout_configs")
}

model WorkoutPlan {
  id String @id @default(uuid())

  name     String
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workoutDays WorkoutDay[]

  @@map("workout_plans")
}

model WorkoutExercise {
  id String @id @default(uuid())

  name              String
  order             Int
  reps              Int
  sets              Int
  restTimeInSeconds Int    @map("rest_time_in_seconds")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workoutDayId String     @map("workout_day_id")
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@map("workout_exercises")
}

model WorkoutDay {
  id                         String  @id @default(uuid())
  name                       String
  isRest                     Boolean @default(false) @map("is_rest")
  estimatedDurationInSeconds Int     @map("estimated_duration_in_seconds")
  coverImageUrl              String  @map("cover_image_url")
  weekDay                    WeekDay @map("week_day")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workoutPlanId String      @map("workout_plan_id")
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  exercises WorkoutExercise[]
  sessions  WorkoutSession[]

  @@map("workout_days")
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model WorkoutSession {
  id String @id @default(uuid())

  startedAt   DateTime  @map("started_at") @db.Timestamptz()
  completedAt DateTime? @map("completed_at") @db.Timestamptz()

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  workoutDayId String     @map("workout_day_id")
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@map("workout_sessions")
}

// HYDRATION:

model HydrationLog {
  id String @id @default(uuid())

  date              DateTime @db.Date
  dailyGoalInMl     Int      @map("daily_goal_in_ml")
  totalConsumedInMl Int      @default(0) @map("total_consumed_in_ml")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  hydrationEntries HydrationEntry[]

  @@unique([userId, date])
  @@map("hydration_logs")
}

model HydrationEntry {
  id String @id @default(uuid())

  amountInMl Int @map("amount_in_ml")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  hydrationLogId String       @map("hydration_log_id")
  hydrationLog   HydrationLog @relation(fields: [hydrationLogId], references: [id], onDelete: Cascade)

  @@index([hydrationLogId])
  @@map("hydration_entries")
}
